# --- Video Source ---
VIDEO_SOURCE=file
VIDEO_PATH=sample.mp4
# RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream1
# WEBCAM_ID=0

# --- Model ---
MODEL_PATH=models/yolo11n.pt
MODEL_NAME=yolo11n
CONF_THRESHOLD=0.5
IOU_THRESHOLD=0.45
DEVICE=cpu

# --- Frame ---
FRAME_WIDTH=1280
FRAME_HEIGHT=720
TARGET_FPS=30
MAX_QUEUE_SIZE=64

# --- Tracker ---
TRACKER_NAME=bytetrack
TRACK_BUFFER=30
MATCH_THRESH=0.8
MIN_HITS=1

# --- Analytics ---
DENSITY_GRID_SCALE=0.1
DENSITY_BANDWIDTH=scott
HEATMAP_DECAY=0.97
HEATMAP_SAVE_INTERVAL=30
ZONES_CONFIG_PATH=config/zones.yaml

# --- Database ---
DATABASE_URL=postgresql+asyncpg://crowd:crowd@localhost:5432/crowd
DATABASE_POOL_SIZE=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=changeme
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173"]

# --- Backend ---
API_PREFIX=/api/v1
BACKEND_PORT=8000

# --- Alert Engine ---
ALERT_COOLDOWN_SECONDS=60
ALERT_CRITICAL_RATIO=2.0

# --- Whole-scene Alerting ---
# When enabled, the entire frame is evaluated against ALERT_SCENE_THRESHOLD
ALERT_SCENE_ENABLED=true
ALERT_SCENE_THRESHOLD=10

# --- Email Alerts (Gmail SMTP example) ---
# NOTE: For Gmail use an App Password (enable 2FA and create App Password)
ALERT_EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Set the Gmail address that will send alerts (use an App Password in SMTP_PASSWORD)
SMTP_USERNAME=yashwankhade25feb@gmail.com
SMTP_PASSWORD=
# Sender must generally match the authenticated account for Gmail
ALERT_EMAIL_FROM=yashwankhade25feb@gmail.com
# Recipient(s) for alerts (set to your address below)
ALERT_EMAIL_TO=["ombhoyar151@gmail.com"]

# --- Telegram Alerts (optional) ---
ALERT_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- General ---
LOG_LEVEL=INFO
OUTPUT_DIR=output
