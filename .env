# --- Video Source ---
VIDEO_SOURCE=file
VIDEO_PATH=scripts/sample.mp4

# --- Model ---
MODEL_PATH=models/yolo11n.pt
MODEL_NAME=yolo11n
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45
DEVICE=cpu

# --- Frame ---
FRAME_WIDTH=1280
FRAME_HEIGHT=720
TARGET_FPS=25
MAX_QUEUE_SIZE=32

# --- Tracker ---
TRACKER_NAME=bytetrack
TRACK_BUFFER=25
MATCH_THRESH=0.8
MIN_HITS=1

# --- Analytics ---
DENSITY_GRID_SCALE=0.1
DENSITY_BANDWIDTH=scott
HEATMAP_DECAY=0.95
HEATMAP_SAVE_INTERVAL=25
ZONES_CONFIG_PATH=config/zones.yaml

# --- Database (SQLite for local dev, no Docker needed) ---
DATABASE_URL=sqlite+aiosqlite:///./crowddb.sqlite3
DATABASE_POOL_SIZE=5

# --- Redis / Celery (memory broker, no Redis needed) ---
REDIS_URL=memory://

# --- JWT ---
JWT_SECRET_KEY=crowdsense-dev-secret-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Backend ---
API_PREFIX=/api/v1
BACKEND_PORT=8000

# --- Alert Engine ---
ALERT_COOLDOWN_SECONDS=30
ALERT_CRITICAL_RATIO=2.0

# --- Email Alerts (enabled) ---
ALERT_EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yashwankhade25feb@gmail.com
SMTP_PASSWORD=kjdv vozd cpzz parr
ALERT_EMAIL_FROM=yashwankhade25feb@gmail.com
ALERT_EMAIL_TO=["ombhoyar151@gmail.com"]

# --- Telegram Alerts (disabled) ---
ALERT_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- General ---
LOG_LEVEL=INFO
OUTPUT_DIR=output
